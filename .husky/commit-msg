# pnpm dlx commitlint --edit "$1"


# ডিফল্ট রানার সেটআপ
DLX_CMD="npx"

# লক-ফাইল অনুযায়ী অটো-ডিটেকশন
if [ -f "pnpm-lock.yaml" ]; then
  DLX_CMD="pnpm dlx"
elif [ -f "bun.lockb" ]; then
  DLX_CMD="bunx"
elif [ -f "yarn.lock" ]; then
  DLX_CMD="yarn dlx"
fi

# ডাইনামিক কমান্ড রান
$DLX_CMD commitlint --edit "$1"